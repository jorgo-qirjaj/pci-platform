# Copy to server/.env on the deploy box and fill in. Do NOT commit the real .env.

NODE_ENV=production
PORT=4000
SERVE_WEB=1                         # API serves the built web app + proxies /slides,/tiles

# Long random secret for signing login tokens.  Generate: openssl rand -hex 32
JWT_SECRET=

# Shared secret for slide uploads — MUST match the value set on the tile server (Railway).
# Generate once: openssl rand -hex 32
UPLOAD_API_KEY=

# Tile server base URL. Phase 1: your existing Railway tile server.
TILE_API_TARGET=https://pci-viewer-production.up.railway.app

# Public origin browsers use (your CloudFront URL). Same-origin in this setup, but set it anyway.
CORS_ORIGIN=https://YOUR-DISTRIBUTION.cloudfront.net

# SQLite location (a writable path on the box). Demo data; reseeds if the file is removed.
PCI_DB_FILE=/home/ubuntu/pci-platform/server/data/pci.db
