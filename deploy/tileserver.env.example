# Tile server env → save as ~/pci-viewer/backend/.env on the box. Local slides; no S3.

# MUST match the platform's UPLOAD_API_KEY (so authenticated uploads are accepted).
UPLOAD_API_KEY=
PORT=8000

# Leave AWS_BUCKET_NAME unset — that keeps the tile server reading slides from the local
# backend/slides/ folder (and uploads land there too). Set it only if you later move to S3.
